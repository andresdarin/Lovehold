# Supabase Postgres (Prisma) — usa pooler (6543) para runtime, directUrl (5432) para migraciones
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require

# Supabase Auth (JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
FRONTEND_URL=http://localhost:3000

# Gemini API (receipt scanning)
GEMINI_API_KEY=
GEMINI_API_MODEL=gemini-2.5-flash
