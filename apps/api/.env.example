# Supabase Postgres (Prisma)
# Pooler regional (IPv4) — necesario porque Render no soporta IPv6 saliente
# El hostname y usuario varían según la región del proyecto
# Sacar de: Supabase Dashboard → Database → Connection Pooling
DATABASE_URL=postgresql://postgres.PROJECT_REF:password@REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.PROJECT_REF:password@REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Supabase Auth (JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret

# CORS
FRONTEND_URL=http://localhost:3000

# Gemini API (receipt scanning)
GEMINI_API_KEY=
GEMINI_API_MODEL=gemini-2.5-flash
