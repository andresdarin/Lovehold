generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id           String   @id @default(cuid())
  authUserId   String   @unique
  email        String   @unique
  displayName  String?
  avatarUrl    String?
  color        String   @default("#6366f1")
  gamificationXp Int    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdHouseholds  Household[]        @relation("householdCreator")
  paidExpenses       Expense[]          @relation("paidBy")
  createdExpenses    Expense[]          @relation("createdBy")
  householdMembers   HouseholdMember[]
  expenseSplits      ExpenseSplit[]
  settlementsSent    Settlement[]       @relation("settlementSender")
  settlementsReceived Settlement[]      @relation("settlementReceiver")
}

model Household {
  id          String   @id @default(cuid())
  name        String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   Profile            @relation("householdCreator", fields: [createdById], references: [id])
  members     HouseholdMember[]
  expenses    Expense[]
  categories  Category[]
  settlements Settlement[]
}

model HouseholdMember {
  id          String   @id @default(cuid())
  householdId String
  profileId   String
  role        String   @default("member")
  joinedAt    DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([householdId, profileId])
}

model Category {
  id          String   @id @default(cuid())
  householdId String
  name        String
  icon        String   @default("tag")
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expenses  Expense[]
}

enum ExpenseItemCategory {
  ALIMENTOS
  VERDURAS
  FRUTAS
  LACTEOS
  CARNES_FIAMBRES
  PANIFICADOS
  BEBIDAS
  ALCOHOL
  SNACKS_DULCES
  HIGIENE
  LIMPIEZA_HOGAR
  MASCOTAS
  OTROS
}

model Expense {
  id          String   @id @default(cuid())
  householdId String
  categoryId  String
  paidById    String
  createdById String
  amount      Decimal  @db.Decimal(10, 2)
  description String
  merchant    String?
  paymentMethod String?
  receiptDate DateTime?
  notes       String?
  date        DateTime
  splitType   String   @default("equal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household  Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category   Category       @relation(fields: [categoryId], references: [id])
  paidBy     Profile        @relation("paidBy", fields: [paidById], references: [id])
  createdBy  Profile        @relation("createdBy", fields: [createdById], references: [id])
  splits     ExpenseSplit[]
  items      ExpenseItem[]
}

model ExpenseSplit {
  id         String  @id @default(cuid())
  expenseId  String
  profileId  String
  amount     Decimal @db.Decimal(10, 2)
  percentage Float?

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([expenseId, profileId])
}

model ExpenseItem {
  id           String              @id @default(cuid())
  expenseId    String
  name         String
  itemCategory ExpenseItemCategory
  quantity     Decimal?            @db.Decimal(10, 3)
  unit         String?
  unitPrice    Decimal?            @db.Decimal(10, 2)
  total        Decimal             @db.Decimal(10, 2)
  rawText      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Settlement {
  id          String   @id @default(cuid())
  householdId String
  fromId      String
  toId        String
  amount      Decimal  @db.Decimal(10, 2)
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  from      Profile   @relation("settlementSender", fields: [fromId], references: [id])
  to        Profile   @relation("settlementReceiver", fields: [toId], references: [id])
}

model PersonalExpense {
  id            String   @id @default(cuid())
  profileId     String
  title         String
  merchant      String?
  amount        Decimal  @db.Decimal(10, 2)
  date          DateTime
  type          String   // fixed | variable | supermarket
  category      String
  notes         String?
  isRecurring   Boolean  @default(false)
  recurrenceDay Int?
  monthKey      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items PersonalExpenseItem[]

  @@index([profileId, monthKey])
}

model PersonalExpenseItem {
  id         String   @id @default(cuid())
  expenseId  String
  name       String
  quantity   Decimal? @db.Decimal(10, 3)
  unitPrice  Decimal? @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  category   String
  rawLine    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  expense PersonalExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([expenseId])
}
